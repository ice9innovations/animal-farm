# Gemini API Vision Service Configuration

# Flask REST API port
PORT=7767
PRIVATE=False

# Google AI Studio API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Model to use — see https://ai.google.dev/gemini-api/docs/models
MODEL=gemini-2.5-flash

# Vision prompt
PROMPT="Briefly describe what you see in this image in a single short sentence. Describe only what is present: people and their actions, animals, objects, setting, and any visible text."

# Max tokens in the response
MAX_TOKENS=75

# Set to false to use local emoji_mappings.json cache only
AUTO_UPDATE=true
