# Florence-2 Multi-Task Vision Service Configuration

# Service Settings
PORT=7803
PRIVATE=False
AUTO_UPDATE=True

# Model Settings
# Options: microsoft/Florence-2-large (default, ~1.5GB), microsoft/Florence-2-base (~230MB)
MODEL_NAME=microsoft/Florence-2-large

# Default task when no 'task' parameter is provided
# Options: CAPTION, DETAILED_CAPTION, MORE_DETAILED_CAPTION, OD, DENSE_REGION_CAPTION,
#          OCR, OCR_WITH_REGION, CAPTION_TO_PHRASE_GROUNDING, OPEN_VOCABULARY_DETECTION,
#          REFERRING_EXPRESSION_SEGMENTATION
DEFAULT_TASK=DENSE_REGION_CAPTION

# Timeout for GitHub config downloads (seconds)
TIMEOUT=10.0

# Model cache directory — set to network volume on RunPod to avoid re-downloading
MODEL_DIR=/workspace/huggingface
