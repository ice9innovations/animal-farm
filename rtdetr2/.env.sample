# RT-DETRv2 Object Detection Configuration

# Service Settings
PORT=7781
PRIVATE=False

# Configuration Updates (GitHub-first pattern)
AUTO_UPDATE=true
TIMEOUT=2.0

# Detection Settings
CONFIDENCE_THRESHOLD=0.25

# NMS Settings
NMS_IOU_THRESHOLD=0.5
MAX_DETECTIONS=100

# Benchmark Mode (disable NMS for COCO evaluation)
# Set to true for COCO benchmarking (returns all 300 raw detections)
# Set to false for production (applies NMS for clean results)
BENCHMARK_MODE=false

# Model Configuration
# Available models: rtdetrv2_s, rtdetrv2_m_r34, rtdetrv2_m_r50, rtdetrv2_l, rtdetrv2_x
# rtdetrv2_s = fastest, smallest model (good for testing)
# rtdetrv2_l = balanced performance/accuracy
# rtdetrv2_x = largest, most accurate (requires more GPU memory)
MODEL_SIZE=rtdetrv2_x