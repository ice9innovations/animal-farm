# llama.cpp Vision API Configuration

# Flask REST API port
PORT=7783
PRIVATE=False

# llama-server binary — built by llama-cpp/build_server.sh
LLAMA_SERVER_BIN=/workspace/llama-server/build/bin/llama-server

# llama-server network config
LLAMA_SERVER_HOST=http://127.0.0.1:11435
LLAMA_SERVER_PORT=11435
N_GPU_LAYERS=99

# Model file paths
# llama3.2-vision (current)
MODEL_PATH=/home/sd/animal-farm/llama-cpp/models/Llama-3.2-11B-Vision-Instruct.Q4_K_M.gguf
MMPROJ_PATH=/home/sd/animal-farm/llama-cpp/models/Llama-3.2-11B-Vision-Instruct-mmproj.f16.gguf
MODEL_NAME=llama3.2-vision

# llava-llama3 (previous — revert by swapping these three values)
#MODEL_PATH=/home/sd/animal-farm/llama-cpp/models/llava-llama3-8b-q4_k_m.gguf
#MMPROJ_PATH=/home/sd/animal-farm/llama-cpp/models/llava-llama3-mmproj-clip.gguf
#MODEL_NAME=llava-llama3

# Vision prompt
PROMPT="Briefly describe this image in a single short sentence including the number and type of people if any are present and what they are doing and any text included in the image, also mentioning nudity and explicit content if applicable."

TEMPERATURE=0.3

# Set to false to use local emoji_mappings.json cache only
AUTO_UPDATE=true
