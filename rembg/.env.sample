PORT=7768
PRIVATE=false

# Backend selector: rembg (CPU/ONNX) or ben2 (GPU/PyTorch)
BACKEND=rembg

# --- rembg backend ---
MODEL_NAME=birefnet-general

# --- ben2 backend ---
# Absolute path to BEN2_Base.pth weights file
# RunPod: /workspace/rembg/models/BEN2_Base.pth
BEN2_MODEL_PATH=/home/sd/bkg/BEN2_Base.pth

# Directory containing BEN2.py (the model class)
# RunPod: /workspace/rembg/BEN2
BEN2_CODE_DIR=/home/sd/ComfyUI/models/RMBG/BEN2

# Optional: enable refined foreground estimation (slower, better edges)
# REFINE_FOREGROUND=false
