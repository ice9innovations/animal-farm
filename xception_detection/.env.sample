# YOLO11n + Xception Detector Configuration

# Service Settings
PORT=7799
SERVICE_NAME=YOLO11n-Xception-Detector
PRIVATE=false

# Model Configuration  
YOLO_MODEL_PATH=yolov8x-seg.pt
DETECTION_THRESHOLD=0.3
CLASSIFICATION_THRESHOLD=0.4
MAX_DETECTIONS=30

XCEPTION_SERVICE_URL=http://localhost:7779

# Performance Settings
IOU_THRESHOLD=0.7