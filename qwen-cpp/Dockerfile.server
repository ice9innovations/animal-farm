# Stage 1: build llama-server with CUDA
FROM nvidia/cuda:12.2.0-devel-ubuntu22.04 AS builder

RUN apt-get update && apt-get install -y \
    git \
    cmake \
    gcc-11 \
    g++-11 \
    && rm -rf /var/lib/apt/lists/*

RUN git clone https://github.com/ggerganov/llama.cpp /build/llama.cpp

WORKDIR /build/llama.cpp

RUN ln -s /usr/local/cuda/lib64/stubs/libcuda.so /usr/local/cuda/lib64/stubs/libcuda.so.1

RUN CC=/usr/bin/gcc-11 CXX=/usr/bin/g++-11 \
    cmake -B build \
    -DGGML_CUDA=ON \
    -DCMAKE_CUDA_ARCHITECTURES=86 \
    -DCMAKE_CUDA_COMPILER=/usr/local/cuda/bin/nvcc \
    -DCMAKE_CUDA_HOST_COMPILER=/usr/bin/g++-11 \
    -DCMAKE_EXE_LINKER_FLAGS="-Wl,-rpath-link,/usr/local/cuda/lib64/stubs" \
    -DCMAKE_SHARED_LINKER_FLAGS="-Wl,-rpath-link,/usr/local/cuda/lib64/stubs" && \
    cmake --build build --config Release -j$(nproc) --target llama-server


# Stage 2: runtime
FROM nvidia/cuda:12.2.0-runtime-ubuntu22.04

RUN apt-get update && apt-get install -y \
    python3.11 \
    python3-pip \
    libgomp1 \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/llama.cpp/build/bin/llama-server /usr/local/bin/llama-server
COPY --from=builder /build/llama.cpp/build/bin/*.so* /usr/local/lib/llama/
RUN echo "/usr/local/lib/llama" > /etc/ld.so.conf.d/llama.conf && ldconfig

WORKDIR /app

RUN pip install \
    flask==3.1.1 \
    flask-cors==6.0.1 \
    python-dotenv==1.1.1 \
    requests==2.32.4 \
    pillow==11.3.0 \
    nltk==3.9.1

COPY emoji_mappings.json /app/
COPY mwe.txt /app/
COPY REST.py /app/
COPY start.sh /app/
RUN chmod +x /app/start.sh

# Models are volume-mounted — never baked into the image:
#   -v /home/sd/animal-farm/qwen-cpp/models:/app/models:ro
# .env must set:
#   MODEL_PATH=/app/models/Qwen2-VL-2B-Instruct-Q4_K_M.gguf
#   MMPROJ_PATH=/app/models/mmproj-Qwen2-VL-2B-Instruct-f16.gguf
#   LLAMA_SERVER_HOST=http://127.0.0.1:11436

EXPOSE 7796

CMD ["/app/start.sh"]
