# qwen-cpp Vision Service Configuration

# Flask REST API port
PORT=7796
PRIVATE=False

# llama-server binary — built by llama-cpp/build_server.sh (shared with qwen-cpp)
LLAMA_SERVER_BIN=/workspace/llama-cpp/build/bin/llama-server

# llama-server network config
LLAMA_SERVER_HOST=http://127.0.0.1:11436
LLAMA_SERVER_PORT=11436
N_GPU_LAYERS=99

# Model file paths (on RunPod, point to /workspace/qwen-cpp/)
MODEL_PATH=/workspace/qwen-cpp/Qwen3VL-2B-Instruct-Q4_K_M.gguf
MMPROJ_PATH=/workspace/qwen-cpp/mmproj-Qwen3VL-2B-Instruct-Q8_0.gguf
MODEL_NAME=qwen3-vl-2b

PROMPT="Briefly describe what you see in this image in a single short sentence. Describe only what is present: people and their actions, animals, objects, setting, and any visible text. If it is not present, do not mention it."

TEMPERATURE=0.3
AUTO_UPDATE=true
