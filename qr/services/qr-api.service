[Unit]
Description=QR Code Scanner API Service
After=network.target

[Service]
Type=simple
User=sd
Group=sd
WorkingDirectory=/home/sd/animal-farm/qr
ExecStart=/home/sd/animal-farm/qr/qr_venv/bin/python REST.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
